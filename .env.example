# Copy file ini menjadi .env, lalu isi credential yang sesuai.

# Wajib: API key Cekat.
cekat_api_key=isi_api_key_di_sini

# Default Open API Cekat.
OPENAPI_LOCAL_SERVER=https://api.cekat.ai

# Opsional: kalau Bearer token berbeda dari cekat_api_key.
# access_token=isi_access_token_di_sini

# MySQL target.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
DB_NAME=cekat_collection_export

# Tuning import.
IMPORT_LIMIT=100
REQUEST_TIMEOUT_MS=30000

# Default aman untuk menghindari rate-limit.
REQUEST_DELAY_MS=3000
RATE_LIMIT_RETRIES=5
RATE_LIMIT_DELAY_MS=120000
